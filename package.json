{
  "name": "medarview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "certs:generate": "npx mkcert create-ca --key certs/ca.key --cert certs/ca.crt && npx mkcert create-cert --ca-key certs/ca.key --ca-cert certs/ca.crt --key certs/lan.key --cert certs/lan.crt --domains localhost 127.0.0.1 192.168.50.108",
    "dev:ui-only": "cross-env VITE_ENABLE_DICTATION=false VITE_ENABLE_EXTERNAL_DICTATION=false vite",
    "dev:full-dictation": "cross-env VITE_ENABLE_DICTATION=true VITE_ENABLE_EXTERNAL_DICTATION=true vite",
    "dev:https:ui-only": "cross-env VITE_DEV_HTTPS=true VITE_ENABLE_DICTATION=false VITE_ENABLE_EXTERNAL_DICTATION=false vite",
    "dev:https:full-dictation": "cross-env VITE_DEV_HTTPS=true VITE_ENABLE_DICTATION=true VITE_ENABLE_EXTERNAL_DICTATION=true vite",
    "gateway:ui-only": "cross-env MEDARVIEW_ENABLE_GOOGLE_SPEECH=false node server/speechGateway.mjs",
    "gateway:full-dictation": "cross-env MEDARVIEW_ENABLE_GOOGLE_SPEECH=true node server/speechGateway.mjs",
    "stack:ui-only": "concurrently -n \"vite,gateway\" -c \"cyan,magenta\" \"npm run dev:ui-only\" \"npm run gateway:ui-only\"",
    "stack:full-dictation": "concurrently -n \"vite,gateway\" -c \"cyan,magenta\" \"npm run dev:full-dictation\" \"npm run gateway:full-dictation\"",
    "ui": "concurrently -n \"vite,gateway\" -c \"cyan,magenta\" \"npm run dev:https:ui-only\" \"npm run gateway:ui-only\"",
    "full": "concurrently -n \"vite,gateway\" -c \"cyan,magenta\" \"npm run dev:https:full-dictation\" \"npm run gateway:full-dictation\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "speech:gateway": "npm run gateway:full-dictation"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/xr": "^6.6.29",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0",
    "three-mesh-ui": "^6.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "mkcert": "^3.2.0",
    "vite": "^8.0.9"
  }
}
