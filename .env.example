VITE_ENABLE_DICTATION=true
VITE_ENABLE_EXTERNAL_DICTATION=true
VITE_DICTATION_PROVIDER=google-medical-proxy
VITE_DICTATION_API_URL=https://your-domain.example.com/speech
VITE_SPEAKER_API_URL=https://your-domain.example.com/diarize
VITE_SPEECH_BUDGET_MINUTES=60
VITE_SPEECH_BUDGET_WINDOW_DAYS=30

MEDARVIEW_DICTATION_PROVIDER=google-medical-proxy
MEDARVIEW_ENABLE_GOOGLE_SPEECH=false
MEDARVIEW_SPEECH_GATEWAY_PORT=8787
MEDARVIEW_GOOGLE_RECOGNIZER=projects/YOUR_PROJECT_NUMBER/locations/global/recognizers/YOUR_RECOGNIZER_ID
MEDARVIEW_GOOGLE_MODEL=latest_long
MEDARVIEW_SPEECH_LANGUAGE=en-US
MEDARVIEW_SPEECH_WS_PATH=/ws/stt
MEDARVIEW_SPEECH_BUDGET_MINUTES=60
MEDARVIEW_SPEECH_BUDGET_WINDOW_DAYS=30

# Set this on the machine running the speech gateway when Google credentials are available.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json